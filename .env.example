# Asana Connection — Environment Variables
# Copy this to .env and fill in your values (or use .asana-api-key file instead)

# Required: Your Asana Personal Access Token
# Get it at: https://app.asana.com/0/my-apps → Developer Console → Personal Access Tokens
ASANA_API_KEY=your_personal_access_token_here

# Required: Your Asana Workspace GID
# Find it by running: npx ts-node cli.ts setup
ASANA_WORKSPACE_GID=your_workspace_gid_here

# Optional: Path to a credential vault file (JSON with sales.asana.access_token)
# CREDENTIAL_VAULT_PATH=/path/to/your/credentials.json
